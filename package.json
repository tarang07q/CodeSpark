{
  "name": "codespark",
  "version": "1.0.0",
  "description": "CodeSpark MERN stack application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "npm start --prefix client",
    "build": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.21.2",
    "mongoose": "^7.0.3",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "html-webpack-plugin": "^5.6.3",
    "nodemon": "^2.0.22"
  }
}
